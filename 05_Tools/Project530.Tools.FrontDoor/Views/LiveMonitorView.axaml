<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Project530.Tools.FrontDoor.ViewModels"
             x:Class="Project530.Tools.FrontDoor.Views.LiveMonitorView"
             x:DataType="vm:ViewModel_LiveMonitor"
             Background="{StaticResource FD_BgVoid}">

  <DockPanel>

    <!-- Top bar -->
    <Border DockPanel.Dock="Top"
            Background="{StaticResource FD_BgPanel}"
            Padding="12,8">
      <StackPanel Orientation="Horizontal" Spacing="16">
        <TextBlock Text="Five30 Live Monitor"
                   FontWeight="Bold" FontSize="16"
                   Foreground="{StaticResource FD_AccentPrimary}"
                   VerticalAlignment="Center" />
        <TextBlock Text="{Binding HealthStatus}"
                   FontSize="12"
                   Foreground="{StaticResource FD_AccentSuccess}"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- Tab strip - buttons switch active page -->
    <Border DockPanel.Dock="Top"
            Background="{StaticResource FD_BgPanel}"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource FD_Border}"
            Padding="4,0">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Button Content="📊 Stats"
                Command="{Binding SelectTabCommand}"
                CommandParameter="0"
                Background="{Binding ActiveTab, Converter={x:Static vm:TabConverters.Stats}}"
                Foreground="{StaticResource FD_TextPrimary}" />
        <Button Content="📋 Live Ops"
                Command="{Binding SelectTabCommand}"
                CommandParameter="1"
                Background="{Binding ActiveTab, Converter={x:Static vm:TabConverters.LiveOps}}"
                Foreground="{StaticResource FD_TextPrimary}" />
        <Button Content="👥 Workforce"
                Command="{Binding SelectTabCommand}"
                CommandParameter="2"
                Background="{Binding ActiveTab, Converter={x:Static vm:TabConverters.Workforce}}"
                Foreground="{StaticResource FD_TextPrimary}" />
        <Button Content="🧠 Brain Pool"
                Command="{Binding SelectTabCommand}"
                CommandParameter="3"
                Background="{Binding ActiveTab, Converter={x:Static vm:TabConverters.BrainPool}}"
                Foreground="{StaticResource FD_TextPrimary}" />
      </StackPanel>
    </Border>

    <!-- Content area - show one page at a time -->
    <ScrollViewer>
      <Grid>
        
        <!-- Page 0: Dashboard Stats (DEFAULT/FRONT PAGE) -->
        <StackPanel Margin="8" Spacing="16" IsVisible="{Binding ActiveTab, Converter={x:Static vm:TabConverters.IsStats}}">
          <TextBlock Text="Dashboard Statistics" FontSize="18" FontWeight="Bold" 
                     Foreground="{StaticResource FD_AccentPrimary}" Margin="0,0,0,8" />
          
          <!-- Stats Grid -->
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <!-- Users -->
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding UserCount}" FontSize="32" FontWeight="Bold" 
                           Foreground="{StaticResource FD_AccentPrimary}" HorizontalAlignment="Center" />
                <TextBlock Text="Users" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <!-- Profiles -->
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding ProfileCount}" FontSize="32" FontWeight="Bold" 
                           Foreground="{StaticResource FD_AccentSuccess}" HorizontalAlignment="Center" />
                <TextBlock Text="Steam Profiles" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <!-- ModPacks -->
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding ModPackCount}" FontSize="32" FontWeight="Bold" 
                           Foreground="{StaticResource FD_AccentSuccess}" HorizontalAlignment="Center" />
                <TextBlock Text="ModPacks" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <!-- Mods -->
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding ModCount}" FontSize="32" FontWeight="Bold" 
                           Foreground="{StaticResource FD_AccentPrimary}" HorizontalAlignment="Center" />
                <TextBlock Text="Total Mods" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </WrapPanel>
          
          <!-- Requests & Results -->
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <!-- Game Requests -->
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding GameRequestCount}" FontSize="32" FontWeight="Bold" 
                           Foreground="{StaticResource FD_AccentPrimary}" HorizontalAlignment="Center" />
                <TextBlock Text="Game Requests" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <!-- Tester Results -->
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding TesterResultCount}" FontSize="32" FontWeight="Bold" 
                           Foreground="{StaticResource FD_AccentSuccess}" HorizontalAlignment="Center" />
                <TextBlock Text="Tester Results" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </WrapPanel>
          
          <!-- Failed Metrics (Alert color) -->
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <TextBlock Text="⚠️ Failed Metrics" FontSize="14" FontWeight="Bold" 
                       Foreground="{StaticResource FD_AccentAlert}" Margin="4,8,4,4" />
          </WrapPanel>
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <!-- Failed ModPacks -->
            <Border Background="{StaticResource FD_BgAlert}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding FailedModPackCount}" FontSize="32" FontWeight="Bold" 
                           Foreground="{StaticResource FD_AccentAlert}" HorizontalAlignment="Center" />
                <TextBlock Text="Failed ModPacks" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <!-- Failed Mods -->
            <Border Background="{StaticResource FD_BgAlert}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding FailedModCount}" FontSize="32" FontWeight="Bold" 
                           Foreground="{StaticResource FD_AccentAlert}" HorizontalAlignment="Center" />
                <TextBlock Text="Failed Mods" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </WrapPanel>
        </StackPanel>

        <!-- Page 1: Live Ops -->
        <Border Margin="8" Padding="8" IsVisible="{Binding ActiveTab, Converter={x:Static vm:TabConverters.IsLiveOps}}"
                Background="{StaticResource FD_BgCard}" CornerRadius="4">
          <StackPanel>
            <TextBlock Text="Live Ops" FontSize="18" FontWeight="Bold" Foreground="{StaticResource FD_AccentPrimary}" Margin="0,0,0,8" />
            <ItemsControl ItemsSource="{Binding LogLines}" Height="400">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas,Courier New"
                             Foreground="{StaticResource FD_TextMuted}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Page 2: Workforce -->
        <StackPanel Margin="8" Spacing="8" IsVisible="{Binding ActiveTab, Converter={x:Static vm:TabConverters.IsWorkforce}}">
          <TextBlock Text="Workforce" FontSize="18" FontWeight="Bold" Foreground="{StaticResource FD_AccentPrimary}" Margin="0,0,0,8" />
          <ItemsControl ItemsSource="{Binding Roster}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="0,4" Padding="12">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource FD_TextPrimary}" />
                    <TextBlock Text="{Binding Role}" FontSize="11" Foreground="{StaticResource FD_TextMuted}" />
                    <TextBlock FontSize="10" Foreground="{StaticResource FD_AccentMuted}">
                      <Run Text="Category: " /><Run Text="{Binding Category}" />
                      <Run Text=" | Status: " /><Run Text="{Binding WorkStreamStatus}" />
                    </TextBlock>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Page 3: Brain Pool -->
        <Border Margin="8" Padding="8" IsVisible="{Binding ActiveTab, Converter={x:Static vm:TabConverters.IsBrainPool}}"
                Background="{StaticResource FD_BgCard}" CornerRadius="4">
          <StackPanel>
            <TextBlock Text="Brain Pool (LLM Models)" FontSize="18" FontWeight="Bold" Foreground="{StaticResource FD_AccentPrimary}" Margin="0,0,0,8" />
            <ItemsControl ItemsSource="{Binding BrainPool}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{StaticResource FD_BgPanel}" CornerRadius="4" Margin="0,2" Padding="8">
                    <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas,Courier New"
                               Foreground="{StaticResource FD_TextPrimary}" />
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

      </Grid>
    </ScrollViewer>

  </DockPanel>

</UserControl>
