<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Project530.Tools.FrontDoor.ViewModels"
             x:Class="Project530.Tools.FrontDoor.Views.LiveMonitorView"
             x:DataType="vm:ViewModel_LiveMonitor"
             Background="{StaticResource FD_BgVoid}">

  <DockPanel>

    <!-- ── Top Status Bar ────────────────────────────────────────── -->
    <Border DockPanel.Dock="Top"
            Background="{StaticResource FD_BgPanel}"
            Padding="12,8">
      <StackPanel Orientation="Horizontal" Spacing="16">
        <TextBlock Text="Five30 Live Monitor"
                   FontWeight="Bold" FontSize="16"
                   Foreground="{StaticResource FD_AccentPrimary}"
                   VerticalAlignment="Center" />
        <TextBlock Text="{Binding HealthStatus}"
                   FontSize="12"
                   Foreground="{StaticResource FD_AccentSuccess}"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- ── Tab Strip ─────────────────────────────────────────────── -->
    <Border DockPanel.Dock="Top"
            Background="{StaticResource FD_BgPanel}"
            BorderThickness="0,0,0,1"
            BorderBrush="{StaticResource FD_Border}"
            Padding="4,0">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Button Content="📊 Stats"
                Command="{Binding SelectTabCommand}"
                CommandParameter="0"
                Background="{Binding ActiveTab, Converter={x:Static vm:TabConverters.Stats}}"
                Foreground="{StaticResource FD_TextPrimary}" />
        <Button Content="📋 Live Ops"
                Command="{Binding SelectTabCommand}"
                CommandParameter="1"
                Background="{Binding ActiveTab, Converter={x:Static vm:TabConverters.LiveOps}}"
                Foreground="{StaticResource FD_TextPrimary}" />
        <Button Content="👥 Workforce"
                Command="{Binding SelectTabCommand}"
                CommandParameter="2"
                Background="{Binding ActiveTab, Converter={x:Static vm:TabConverters.Workforce}}"
                Foreground="{StaticResource FD_TextPrimary}" />
        <Button Content="🧠 Brain Pool"
                Command="{Binding SelectTabCommand}"
                CommandParameter="3"
                Background="{Binding ActiveTab, Converter={x:Static vm:TabConverters.BrainPool}}"
                Foreground="{StaticResource FD_TextPrimary}" />
        <Button Content="🤖 AI Agents"
                Command="{Binding SelectTabCommand}"
                CommandParameter="4"
                Background="{Binding ActiveTab, Converter={x:Static vm:TabConverters.AiAgents}}"
                Foreground="{StaticResource FD_TextPrimary}" />
      </StackPanel>
    </Border>

    <!-- ── Content Area ──────────────────────────────────────────── -->
    <ScrollViewer>
      <Grid>

        <!-- ─ Page 0: Dashboard Stats ─────────────────────────── -->
        <StackPanel Margin="8" Spacing="16"
                    IsVisible="{Binding ActiveTab, Converter={x:Static vm:TabConverters.IsStats}}">
          <TextBlock Text="Dashboard Statistics" FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource FD_AccentPrimary}" Margin="0,0,0,8" />
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding UserCount}" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource FD_AccentPrimary}" HorizontalAlignment="Center" />
                <TextBlock Text="Users" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding ProfileCount}" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource FD_AccentSuccess}" HorizontalAlignment="Center" />
                <TextBlock Text="Steam Profiles" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding ModPackCount}" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource FD_AccentSuccess}" HorizontalAlignment="Center" />
                <TextBlock Text="ModPacks" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding ModCount}" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource FD_AccentPrimary}" HorizontalAlignment="Center" />
                <TextBlock Text="Total Mods" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </WrapPanel>
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding GameRequestCount}" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource FD_AccentPrimary}" HorizontalAlignment="Center" />
                <TextBlock Text="Game Requests" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding TesterResultCount}" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource FD_AccentSuccess}" HorizontalAlignment="Center" />
                <TextBlock Text="Tester Results" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </WrapPanel>
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <TextBlock Text="⚠️ Failed Metrics" FontSize="14" FontWeight="Bold"
                       Foreground="{StaticResource FD_AccentAlert}" Margin="4,8,4,4" />
          </WrapPanel>
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Border Background="{StaticResource FD_BgAlert}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding FailedModPackCount}" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource FD_AccentAlert}" HorizontalAlignment="Center" />
                <TextBlock Text="Failed ModPacks" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border Background="{StaticResource FD_BgAlert}" CornerRadius="4" Margin="4" Padding="20,16" MinWidth="140">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding FailedModCount}" FontSize="32" FontWeight="Bold"
                           Foreground="{StaticResource FD_AccentAlert}" HorizontalAlignment="Center" />
                <TextBlock Text="Failed Mods" FontSize="12" Foreground="{StaticResource FD_TextMuted}" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </WrapPanel>
        </StackPanel>

        <!-- ─ Page 1: Live Ops ────────────────────────────────── -->
        <StackPanel Margin="8" Spacing="8"
                    IsVisible="{Binding ActiveTab, Converter={x:Static vm:TabConverters.IsLiveOps}}">
          <TextBlock Text="Live Ops" FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource FD_AccentPrimary}" Margin="0,0,0,8" />

          <!-- Work Plans section -->
          <TextBlock Text="Active Work Plans" FontSize="14" FontWeight="SemiBold"
                     Foreground="{StaticResource FD_TextPrimary}" />
          <ItemsControl ItemsSource="{Binding Plans}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="0,3" Padding="12,10">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding PlanId}" FontWeight="Bold" FontSize="13"
                               FontFamily="Consolas,Courier New"
                               Foreground="{StaticResource FD_AccentPrimary}" />
                    <TextBlock FontSize="11" Foreground="{StaticResource FD_TextMuted}">
                      <Run Text="Lead: " />
                      <Run Text="{Binding Lead.Name}" />
                      <Run Text="  |  Category: " />
                      <Run Text="{Binding Lead.Category}" />
                    </TextBlock>
                    <TextBlock Text="{Binding Lead.WorkStreamStatus}" FontSize="11"
                               Foreground="{StaticResource FD_AccentSuccess}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Factory log stream -->
          <TextBlock Text="Factory Log Stream" FontSize="14" FontWeight="SemiBold"
                     Foreground="{StaticResource FD_TextPrimary}" Margin="0,12,0,0" />
          <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Padding="8">
            <ItemsControl ItemsSource="{Binding LogLines}" Height="300">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}" FontSize="11" FontFamily="Consolas,Courier New"
                             Foreground="{StaticResource FD_TextMuted}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>
        </StackPanel>

        <!-- ─ Page 2: Workforce ───────────────────────────────── -->
        <StackPanel Margin="8" Spacing="8"
                    IsVisible="{Binding ActiveTab, Converter={x:Static vm:TabConverters.IsWorkforce}}">
          <TextBlock Text="Workforce" FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource FD_AccentPrimary}" Margin="0,0,0,8" />
          <ItemsControl ItemsSource="{Binding Roster}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="0,4" Padding="12">
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource FD_TextPrimary}" />
                    <TextBlock Text="{Binding Role}" FontSize="11" Foreground="{StaticResource FD_TextMuted}" />
                    <TextBlock FontSize="10" Foreground="{StaticResource FD_AccentMuted}">
                      <Run Text="Category: " /><Run Text="{Binding Category}" />
                      <Run Text=" | Status: " /><Run Text="{Binding WorkStreamStatus}" />
                    </TextBlock>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- ─ Page 3: Brain Pool ──────────────────────────────── -->
        <Border Margin="8" Padding="8"
                IsVisible="{Binding ActiveTab, Converter={x:Static vm:TabConverters.IsBrainPool}}"
                Background="{StaticResource FD_BgCard}" CornerRadius="4">
          <StackPanel>
            <TextBlock Text="Brain Pool (LLM Models)" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource FD_AccentPrimary}" Margin="0,0,0,8" />
            <ItemsControl ItemsSource="{Binding BrainPool}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{StaticResource FD_BgPanel}" CornerRadius="4" Margin="0,2" Padding="10,8">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding ModelId}" FontSize="12" FontFamily="Consolas,Courier New"
                                   Foreground="{StaticResource FD_TextPrimary}" />
                        <TextBlock Text="{Binding Provider}" FontSize="11"
                                   Foreground="{StaticResource FD_AccentPrimary}" />
                      </StackPanel>
                      <Border Grid.Column="1" Background="{StaticResource FD_AccentSuccess}" CornerRadius="3"
                              Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource FD_BgVoid}" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- ─ Page 4: AI Agent APIs ───────────────────────────── -->
        <StackPanel Margin="8" Spacing="8"
                    IsVisible="{Binding ActiveTab, Converter={x:Static vm:TabConverters.IsAiAgents}}">
          <TextBlock Text="AI Agent APIs" FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource FD_AccentPrimary}" Margin="0,0,0,8" />

          <!-- Configured entries list -->
          <ItemsControl ItemsSource="{Binding AiAgents}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Margin="0,3" Padding="12,10">
                  <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding Provider}" FontWeight="Bold" FontSize="13"
                                 Foreground="{StaticResource FD_TextPrimary}" />
                      <TextBlock Text="{Binding Endpoint}" FontSize="11" FontFamily="Consolas,Courier New"
                                 Foreground="{StaticResource FD_TextMuted}" />
                      <TextBlock Text="{Binding MaskedKey}" FontSize="11" FontFamily="Consolas,Courier New"
                                 Foreground="{StaticResource FD_AccentMuted}" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="{StaticResource FD_AccentSuccess}" CornerRadius="3"
                            Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold"
                                 Foreground="{StaticResource FD_BgVoid}" />
                    </Border>
                    <Button Grid.Column="2" Content="Remove" Margin="8,0,0,0"
                            Command="{Binding $parent[UserControl].((vm:ViewModel_LiveMonitor)DataContext).RemoveAiAgentCommand}"
                            CommandParameter="{Binding Provider}"
                            Background="{StaticResource FD_AccentDanger}"
                            Foreground="{StaticResource FD_TextPrimary}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Add new provider form -->
          <Border Background="{StaticResource FD_BgCard}" CornerRadius="4" Padding="14" Margin="0,10,0,0">
            <StackPanel Spacing="10">
              <TextBlock Text="Add New Provider" FontSize="14" FontWeight="SemiBold"
                         Foreground="{StaticResource FD_TextPrimary}" />
              <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Provider Name"
                           VerticalAlignment="Center" Foreground="{StaticResource FD_TextMuted}" FontSize="12" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NewProviderName}"
                         Watermark="e.g. openrouter, gemini, groq" Margin="0,4" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Endpoint URL"
                           VerticalAlignment="Center" Foreground="{StaticResource FD_TextMuted}" FontSize="12" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewEndpoint}"
                         Watermark="https://openrouter.ai/api/v1" Margin="0,4" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="API Key"
                           VerticalAlignment="Center" Foreground="{StaticResource FD_TextMuted}" FontSize="12" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewApiKey}"
                         PasswordChar="•" Watermark="sk-..." Margin="0,4" />
              </Grid>
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Add Provider" Command="{Binding AddAiAgentCommand}"
                        Background="{StaticResource FD_AccentPrimary}"
                        Foreground="{StaticResource FD_TextPrimary}" />
                <TextBlock Text="{Binding AiAgentStatusMessage}" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource FD_AccentWarning}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

      </Grid>
    </ScrollViewer>

  </DockPanel>

</UserControl>
